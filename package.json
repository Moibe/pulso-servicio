{
	"name": "pulso-servicio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "node --env-file=.env scripts/migrate.mjs",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "node --env-file=.env scripts/seed.mjs",
		"db:reset-password": "node --env-file=.env scripts/reset-password.mjs",
		"db:espejo-pull": "node --env-file=.env scripts/espejo-pull.mjs",
		"db:espejo-apply": "node --env-file=.env scripts/espejo-apply.mjs",
		"db:espejo-push": "node --env-file=.env scripts/espejo-push.mjs"
	},
	"dependencies": {
		"better-sqlite3": "^12.9.0",
		"drizzle-orm": "^0.45.2"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.0",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
